<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- User Profile Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Recourse.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/userName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/userEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/userRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="@color/surface_variant"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/recourse_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Company Details -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Company Context"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:textColor="@color/text_muted"
            android:layout_marginTop="24dp"
            android:layout_marginStart="4dp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Recourse.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/companyName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/companyIndustry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/companyRegion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="14sp"
                    android:textColor="@color/recourse_primary_light"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/sandboxStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="#FFF3E0"
                    android:text="Sandbox Active"
                    android:textSize="11sp"
                    android:textColor="#E65100"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/brokerCapacityBadge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:padding="10dp"
                    android:background="#E1F5FE"
                    android:text="Verified A-Rated Reinsurance Capacity"
                    android:textSize="11sp"
                    android:textColor="#0277BD"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Active Subscriptions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active Subscriptions"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:textColor="@color/text_muted"
            android:layout_marginTop="24dp"
            android:layout_marginStart="4dp" />

        <TextView
            android:id="@+id/subscriptionSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="16dp"
            android:background="@drawable/bg_status_pill"
            android:backgroundTint="@color/surface_variant"
            android:textColor="@color/text_primary" />

        <!-- Metrics Dashboard -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Executive Metrics"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:textColor="@color/text_muted"
            android:layout_marginTop="24dp"
            android:layout_marginStart="4dp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Recourse.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2">

                    <!-- Metric 1: Total Recovered -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Recovered"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:textColor="@color/text_muted" />
                        <TextView
                            android:id="@+id/totalClaimedText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/status_success" />
                    </LinearLayout>

                    <!-- Metric 2: Loss Ratio -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loss Ratio"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:textColor="@color/text_muted" />
                        <TextView
                            android:id="@+id/lossRatioText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0%"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <!-- Metric 3: Time Saved -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Time Saved"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:textColor="@color/text_muted" />
                        <TextView
                            android:id="@+id/timeSavedText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+0 Days"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#1565C0" />
                    </LinearLayout>

                    <!-- Metric 4: Risk Reduction -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Risk Redux"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:textColor="@color/text_muted" />
                        <TextView
                            android:id="@+id/riskReductionText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+0%"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/recourse_secondary_dark" />
                    </LinearLayout>

                </GridLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginHorizontal="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/avgRecoveryTimeText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/guardrailTrendText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="13sp"
                        android:textColor="@color/recourse_secondary_dark"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/industryBenchmarkText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="12sp"
                        android:textStyle="italic"
                        android:textColor="@color/status_critical" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginHorizontal="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/committedCapacityText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/brokerReferralText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/brokerCommissionText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="13sp"
                        android:textColor="@color/status_success"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Management Actions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Management"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:textColor="@color/text_muted"
            android:layout_marginTop="24dp"
            android:layout_marginStart="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/upgradeSubscriptionButton"
            style="@style/Widget.Recourse.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Upgrade Subscription"
            app:icon="@android:drawable/ic_input_add" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/generateTrustSealButton"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Generate Trust Seal"
            app:icon="@android:drawable/ic_dialog_info" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/viewVentureRisksButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Venture Risk Register"
                android:gravity="start|center_vertical"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/viewGlossaryButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Executive Glossary"
                android:gravity="start|center_vertical" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/viewRoadmapButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Strategic Roadmap"
                android:gravity="start|center_vertical"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/viewMarketButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Market Intelligence"
                android:gravity="start|center_vertical"
                android:visibility="gone" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="100dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>