<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Recourse" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/recourse_primary</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorPrimaryContainer">@color/recourse_primary_light</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/recourse_secondary</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background/Surface -->
        <item name="android:windowBackground">@color/bg_app</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/recourse_primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Typography -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Recourse.HeadlineLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Recourse.TitleMedium</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Recourse.BodyLarge</item>
    </style>

    <style name="TextAppearance.Recourse.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Recourse.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Recourse.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.Recourse.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
    </style>

    <style name="Widget.Recourse.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">8dp</item>
    </style>
</resources>